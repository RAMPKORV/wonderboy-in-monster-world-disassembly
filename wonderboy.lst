000A3500                            Bank080000_TableTargetedPayload_0A3500:
000A3500                            	include "src/z80_offset_bank/offset_tree_targeted_records.asm"
000A3500                            ; ROM range: 0x0A3500-0x0A4C76
000A3500                            ; Table-targeted payload record starts reached from the nested 0x0A0000-0x0A07C5 offset tree.
000A3500                            ; The table evidence proves stable ROM-order boundaries across the back half of this island,
000A3500                            ; so keep those targets explicit even though the higher-level loader and record semantics are
000A3500                            ; still unresolved.
000A3500                            
000A3500                            	include "src/z80_offset_bank/offset_tree_targeted_records_front.asm"
000A3500                            ; ROM range: 0x0A3500-0x0A37AF
000A3500                            ; Front source-authored slice of the 0x0A3500+ table-targeted back half.
000A3500                            ;
000A3500                            ; The nested offset tree already proved these starts, and the bytes here are compact enough
000A3500                            ; to expose directly without forcing stronger subsystem meaning. The strongest current fit is
000A3500                            ; structural: most records begin with a repeated FC/FB prefix, carry local 24-bit offsets back
000A3500                            ; into the earlier 0x0A07C6-0x0A0D80 tuple families, and end in short FF/FD-terminated selector
000A3500                            ; tails.
