00099AE5 0000 0000 0000 0000 0000+  	dc.b	$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00
00099AF5 0000 0000 0000 0000 0000+  	dc.b	$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00
