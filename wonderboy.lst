00098000                            Bank080000_Z80Resources_098000_09F776:
00098000                            	include "src/z80_offset_bank/z80_resources.asm"
00098000                            ; ROM range: 0x098000-0x09F776
00098000                            ; Conservative split of the first non-fill tail-bank island. The front 0x098000-0x0991FF
00098000                            ; span still begins with a strongly Z80/opcode-dense code body rather than plain 68k or
00098000                            ; obvious asset data, but it no longer stays monolithic: the final 0x185 bytes are now
00098000                            ; explicit as two odd-aligned little-endian word lookup tables and one trailing zero byte.
00098000                            ; The next 0x099200-0x09991F span is also split separately because it is structurally cleaner:
00098000                            ; monotone byte bands, a fixed 19-byte record family, smaller mixed/control tails, and a short
00098000                            ; local-offset/word trailer leading into the already split descriptor-header region plus the
00098000                            ; adjacent fixed-record layout band. The larger command region still keeps its front lead-in
00098000                            ; and bank-local offset table explicit before the denser command records, and the formerly
00098000                            ; monolithic trailing command body at 0x09A348-0x09F776 remains divided into three ROM-order
00098000                            ; source windows, each further split at every proven local 0xFF terminator so the
00098000                            ; command-record cadence is explicit even before the subsystem owner is clearer.
00098000                            
00098000                            Bank080000_Z80Program_098000:
00098000                            	include "src/z80_offset_bank/z80_program.asm"
00098000                            ; ROM range: 0x098000-0x0991FF
00098000                            ; Front slice inside the 0x098000-0x09F776 non-fill tail-bank island.
00098000                            ;
00098000                            ; The bytes at 0x098000 are now strong enough to treat this as a real Z80 program front
00098000                            ; rather than a merely Z80-like blob: the bank opens with `DI`, `IM 1`, and an absolute
00098000                            ; `JP $003B`, later front stubs repeatedly `JP $0F8C`, and 0x098038 is a tiny `NOP`/`RETI`
00098000                            ; handler immediately before the jumped-to main body at 0x09803B.
00098000                            ;
00098000                            ; Keep the names structural until the higher-level owner is proven. The front stubs are
00098000                            ; visible because their entry boundaries are now stronger than the rest of the opcode-dense
00098000                            ; body, but the wider loader path still does not prove whether this is the sound driver,
00098000                            ; another Z80-resident helper, or a banked interpreter payload.
00098000                            ;
00098000                            ; The full 0x098000-0x0991FF front slice is now source-visible. The 0x09803B-0x09907A
00098000                            ; body still keeps structural names because the wider loader path is unresolved, but the
00098000                            ; former 0x09803B-0x098274 incbin now stands as startup, sequencing, and slot-management
00098000                            ; helpers before the later explicit meta-command dispatch and lookup tables. The final
00098000                            ; 0x185 bytes stay explicit source data too: the first table at 0x09907B-0x09913C rises
00098000                            ; from 0x028E to 0x051C across 97 entries, while the second at 0x09913D-0x0991FE falls
00098000                            ; from 0x0349 to 0x01A4 across another 97 entries.
00098000                            
00098000                            Bank080000_Z80ProgramBlock_098000:
00098000                            
00098000                            ; The opening bytes are no longer kept inside one monolithic incbin: 0x098000 jumps to the
00098000                            ; later main entry at 0x09803B, 0x098020/0x098028/0x098030 are repeated absolute jump stubs,
00098000                            ; and 0x098038 is a tiny `NOP`/`RETI` handler.
00098000                            Bank080000_Z80ProgramResetEntry_098000:
00098000 F3ED 56C3 3B00             	dc.b	$F3,$ED,$56,$C3,$3B,$00
00098006                            
00098006                            Bank080000_Z80ProgramFrontReturnStub_098006:
00098006 771A 7223 0B78 B120 F9C9   	dc.b	$77,$1A,$72,$23,$0B,$78,$B1,$20,$F9,$C9
00098010                            
00098010                            ; 0x098010-0x09801F remains a mixed front-stub pocket, but the three following 8-byte runs
00098010                            ; are strong enough to stand on their own because they all repeat the same absolute `JP $0F8C`
00098010                            ; handoff shape.
00098010                            Bank080000_Z80ProgramFrontStubCluster_098010:
00098010 DFDF DF1C C9FF FFFF 7B42+  	dc.b	$DF,$DF,$DF,$1C,$C9,$FF,$FF,$FF,$7B,$42,$CD,$CB,$06,$1C,$C9,$FF
00098020                            
00098020                            Bank080000_Z80ProgramJumpStub_098020:
00098020 E32B E3C3 8C0F FFFF        	dc.b	$E3,$2B,$E3,$C3,$8C,$0F,$FF,$FF
00098028                            
00098028                            Bank080000_Z80ProgramJumpStub_098028:
