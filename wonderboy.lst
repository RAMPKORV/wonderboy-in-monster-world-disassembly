000A0C83                            Bank080000_FFTerminatedSixByteRecordFamilies_0A0C83:
000A0C83                            	include "src/z80_offset_bank/ff_terminated_six_byte_records.asm"
000A0C83                            ; ROM range: 0x0A0C83-0x0A10AA
000A0C83                            ; Narrower structural split inside the still-mixed 0x0A0B26-0x0A34FF lead-in. Several
000A0C83                            ; subranges here resolve into regular 6-byte records whose final byte is always $FF, with
000A0C83                            ; small inter-band gaps that are no longer opaque either: the first and last ones break
000A0C83                            ; into neighboring FF-terminated tuple records plus short non-terminated tails, while the
000A0C83                            ; middle pocket is itself another compact FF-terminated record family with one trailing
000A0C83                            ; singleton $FF marker. The higher-level owner and field semantics are still open, so keep
000A0C83                            ; the naming at record-band level.
