0002482C                            ; ROM range: 0x02482C-0x03FFFF
0002482C                            ; Tail region of bank 020000.
0002482C                            ;
0002482C                            ; Structure:
0002482C                            ;   0x02482C  4-entry relative-offset table (10 bytes, terminated by 0xFF7B sentinel)
0002482C                            ;             Offsets are relative to the table base (0x02482C):
0002482C                            ;               0x0016 -> 0x024842  (sub-entry 0 within Block 1 RLE data)
0002482C                            ;               0x007A -> 0x0248A6  (sub-entry 1 within Block 1 RLE data)
0002482C                            ;               0x00EA -> 0x024916  (sub-entry 2 within Block 1 RLE data)
0002482C                            ;               0x015E -> 0x02498A  (sub-entry 3 within Block 1 RLE data)
0002482C                            ;               0xFF7B              (end-of-table sentinel)
0002482C                            ;   0x024836  RLE/compressed graphics data blocks, each terminated by 0xFF7B.
0002482C                            ;             Blocks 1-9 are confirmed by 0xFF7B terminators.
0002482C                            ;   0x035078  More compressed/data blocks. The next three are terminated by
0002482C                            ;             0xFF7A instead, and only the final 0x03C6E0-0x03FFFF tail still
0002482C                            ;             lacks a proven internal split.
0002482C                            ;
0002482C                            ; The 0x52, 0x4A, 0x5A byte values within block payloads are RLE opcodes;
0002482C                            ; 0xFF-heavy runs are fill patterns. This is consistent with Mega Drive
0002482C                            ; tile/sprite compressed graphics formats.
0002482C                            
0002482C                            ; --- Offset table (0x02482C-0x024835, 10 bytes) ---
0002482C                            ; 4 relative offsets into Block 1 payload + 0xFF7B end-of-table sentinel.
0002482C                            Bank020000_TailOffsetTable_02482C:
0002482C 0016 007A 00EA 015E FF7B   	dc.w	$0016,$007A,$00EA,$015E,$FF7B
00024836                            
00024836                            ; --- Block 1 (0x024836-0x025125, 2288 bytes) ---
00024836                            ; RLE-compressed graphics block. 12-byte header at 0x024836 followed by
00024836                            ; sub-entries at offsets 0x0016, 0x007A, 0x00EA, 0x015E from the offset table
00024836                            ; base (0x02482C). Block terminated by 0xFF7B at 0x025124.
00024836                            Bank020000_TailGfxBlock1_024836:
00024836                            	incbin "data/rom/bank_020000_03ffff.bin",$004836,$0008F0
00025126                            
00025126                            ; --- Block 2 (0x025126-0x0289B7, 14482 bytes) ---
00025126                            ; RLE-compressed graphics block, header 0x0B60... Terminated by 0xFF7B at 0x0289B6.
00025126                            Bank020000_TailGfxBlock2_025126:
00025126                            	incbin "data/rom/bank_020000_03ffff.bin",$005126,$003892
000289B8                            
000289B8                            ; --- Block 3 (0x0289B8-0x02AE74, 9405 bytes) ---
000289B8                            ; RLE-compressed graphics block, header 0x1161... Terminated by 0xFF7B at 0x02AE73.
000289B8                            Bank020000_TailGfxBlock3_0289B8:
000289B8                            	incbin "data/rom/bank_020000_03ffff.bin",$0089B8,$0024BD
0002AE75                            
0002AE75                            ; --- Block 4 (0x02AE75-0x02F70F, 18587 bytes) ---
0002AE75                            ; RLE-compressed graphics block, header 0x7F63... Terminated by 0xFF7B at 0x02F70E.
0002AE75                            Bank020000_TailGfxBlock4_02AE75:
0002AE75                            	incbin "data/rom/bank_020000_03ffff.bin",$00AE75,$00489B
0002F710                            
0002F710                            ; --- Block 5 (0x02F710-0x030479, 3434 bytes) ---
0002F710                            ; Compressed/bitfield data block, header 0x8F07... Terminated by 0xFF7B at 0x030478.
0002F710                            Bank020000_TailGfxBlock5_02F710:
0002F710                            	incbin "data/rom/bank_020000_03ffff.bin",$00F710,$000D6A
0003047A                            
0003047A                            ; --- Block 6 (0x03047A-0x0304ED, 116 bytes) ---
0003047A                            ; Compressed/bitfield data block, header 0x0F03... Terminated by 0xFF7B at 0x0304EC.
0003047A                            Bank020000_TailGfxBlock6_03047A:
0003047A                            	incbin "data/rom/bank_020000_03ffff.bin",$01047A,$000074
000304EE                            
000304EE                            ; --- Block 7 (0x0304EE-0x03140D, 3872 bytes) ---
000304EE                            ; Compressed/bitfield data block, same header pattern as Block 6 (0x0F03...).
000304EE                            ; Terminated by 0xFF7B at 0x03140C.
000304EE                            Bank020000_TailGfxBlock7_0304EE:
000304EE                            	incbin "data/rom/bank_020000_03ffff.bin",$0104EE,$000F20
0003140E                            
0003140E                            ; --- Block 8 (0x03140E-0x034AEB, 14046 bytes) ---
0003140E                            ; Compressed/bitfield data block, header 0xC0FB... Terminated by 0xFF7B at 0x034AEA.
0003140E                            Bank020000_TailGfxBlock8_03140E:
0003140E                            	incbin "data/rom/bank_020000_03ffff.bin",$01140E,$0036DE
00034AEC                            
00034AEC                            ; --- Block 9 (0x034AEC-0x035077, 1420 bytes) ---
00034AEC                            ; RLE-compressed graphics block, header 0x0660... Terminated by 0xFF7B at 0x035076.
00034AEC                            Bank020000_TailGfxBlock9_034AEC:
00034AEC                            	incbin "data/rom/bank_020000_03ffff.bin",$014AEC,$00058C
00035078                            
00035078                            ; --- Block 10 (0x035078-0x03519D, 294 bytes) ---
00035078                            ; Compact compressed/data block, header 0x0660... Terminated by 0xFF7A at 0x03519C.
00035078                            Bank020000_TailGfxBlock10_035078:
00035078                            	incbin "data/rom/bank_020000_03ffff.bin",$015078,$000126
0003519E                            
0003519E                            ; --- Block 11 (0x03519E-0x0354F3, 854 bytes) ---
0003519E                            ; Compact compressed/data block, header 0x0B60... Terminated by 0xFF7A at 0x0354F2.
0003519E                            Bank020000_TailGfxBlock11_03519E:
0003519E                            	incbin "data/rom/bank_020000_03ffff.bin",$01519E,$000356
000354F4                            
000354F4                            ; --- Block 12 (0x0354F4-0x03C6DF, 29164 bytes) ---
000354F4                            ; Larger compressed/data block, header 0x0F00... Terminated by 0xFF7A at 0x03C6DE.
000354F4                            Bank020000_TailGfxBlock12_0354F4:
000354F4                            	incbin "data/rom/bank_020000_03ffff.bin",$0154F4,$0071EC
0003C6E0                            
0003C6E0                            ; --- Final tail continuation (0x03C6E0-0x03FFFF, 14624 bytes) ---
0003C6E0                            ; This bank end still lacks proven 0xFF7A/0xFF7B terminators, but several later internal
0003C6E0                            ; starts are now called out explicitly because they begin with the same 0x0960 / 0x0F00 /
0003C6E0                            ; 0x0B60-style header-like prefixes already seen in earlier tail blocks. Keep the names
0003C6E0                            ; structural until a loader or decompressor proves whether these are true block headers,
0003C6E0                            ; format variants, or nested substreams.
0003C6E0                            	include "src/text_bank/compressed_data_remainder.asm"
0003C6E0                            ; ROM range: 0x03C6E0-0x03FFFF
0003C6E0                            ; Header-like sub-block split inside the final bank020000 compressed/data tail.
0003C6E0                            ;
0003C6E0                            ; These boundaries are weaker than the earlier 0xFF7A/0xFF7B-terminated blocks, but they
0003C6E0                            ; are still useful ROM-order structure: the bytes at 0x03C6E0, 0x03E846, 0x03EF4E,
0003C6E0                            ; 0x03F4D1, and 0x03FE24 each begin with the same short header-like prefixes already seen
0003C6E0                            ; at earlier proven block starts in this tail. Until a caller or decoder proves the exact
0003C6E0                            ; format, keep the ownership conservative and the labels structural.
0003C6E0                            
0003C6E0                            ; --- Candidate block A (0x03C6E0-0x03E845, 8550 bytes) ---
0003C6E0                            ; Starts with 0x0960..., which does not appear elsewhere in the earlier proven set.
0003C6E0                            Bank020000_TailHeaderLikeDataBlockA_03C6E0:
0003C6E0                            	incbin "data/rom/bank_020000_03ffff.bin",$01C6E0,$002166
0003E846                            
0003E846                            ; --- Candidate block B (0x03E846-0x03EF4D, 1800 bytes) ---
0003E846                            ; Starts with 0x0F00..., matching one of the recurring block-header-like prefixes.
0003E846                            Bank020000_TailHeaderLikeDataBlockB_03E846:
0003E846                            	incbin "data/rom/bank_020000_03ffff.bin",$01E846,$000708
0003EF4E                            
0003EF4E                            ; --- Candidate block C (0x03EF4E-0x03F4D0, 1411 bytes) ---
0003EF4E                            ; Starts with 0x0B60..., another recurring prefix already seen at earlier tail starts.
0003EF4E                            Bank020000_TailHeaderLikeDataBlockC_03EF4E:
0003EF4E                            	incbin "data/rom/bank_020000_03ffff.bin",$01EF4E,$000583
0003F4D1                            
0003F4D1                            ; --- Candidate block D (0x03F4D1-0x03FE23, 2387 bytes) ---
0003F4D1                            ; Starts with 0x0F00... and runs to the next later header-like prefix.
0003F4D1                            Bank020000_TailHeaderLikeDataBlockD_03F4D1:
0003F4D1                            	incbin "data/rom/bank_020000_03ffff.bin",$01F4D1,$000953
0003FE24                            
0003FE24                            ; --- Candidate block E (0x03FE24-0x03FFFF, 476 bytes) ---
0003FE24                            ; Final short bank-end tail. Also starts with 0x0F00..., but no later internal boundary is
0003FE24                            ; currently better justified before the bank end.
0003FE24                            Bank020000_TailHeaderLikeDataBlockE_03FE24:
0003FE24                            	incbin "data/rom/bank_020000_03ffff.bin",$01FE24,$0001DC
0003FE24                            	incbin "data/rom/bank_020000_03ffff.bin",$01FE24,$0001DC
0003FE24                            	incbin "data/rom/bank_020000_03ffff.bin",$01FE24,$0001DC
0003FE24                            	incbin "data/rom/bank_020000_03ffff.bin",$01FE24,$0001DC
00040000                            	include "src/reference_gfx_bank.asm"
00040000                            ; ======================================================================
00040000                            ; src/reference_gfx_bank.asm
00040000                            ; ROM range: 0x040000-0x07FFFF - late-ROM tables, payloads, and graphics slices
00040000                            ; ======================================================================
00040000                            ; Late-ROM bank split into bank-local slices. The first confirmed structure here was a
00040000                            ; long 0xFF fill run at 0x0409FA-0x040FFF; the next proven cluster at 0x041000-0x041BFF is
00040000                            ; now explicit as a flagged ROM-reference table island with two smaller 0xFF fill gaps, and
00040000                            ; the first four chunks of its local-target payload family are split further at
00040000                            ; 0x041C00-0x07FF66, leaving only a tiny trailing bank remainder.
00040000                            
00040000                            Bank040000_FrontHeaderLikeData_040000:
00040000                            	include "src/reference_gfx_bank/front_data_blocks.asm"
00040000                            ; ROM range: 0x040000-0x0409F9
00040000                            ; Front data island before the explicit 0x0409FA-0x040FFF fill run.
00040000                            ;
00040000                            ; This span is still opaque at the subsystem level, but it no longer needs to stay as one
00040000                            ; monolithic incbin. Several recurring header-like starts are now explicit in ROM order:
00040000                            ;   0x040100  starts with FFFF 000A
00040000                            ;   0x04025C  starts with FFFF 000E
00040000                            ;   0x040400  starts with 0000 0102 ... FFFF 001E
00040000                            ;   0x04053C  starts with 0000 0102 ... FFFF 000E
00040000                            ;   0x0406C4  starts with FFFF 000A
00040000                            ;   0x0408D4  starts with FFFF 000A
00040000                            ; Those signatures recur within the same front slice and mark cleaner boundaries than one
00040000                            ; bank-front blob, even though the loader and exact format are still unresolved.
00040000                            
00040000                            ; --- Front lead-in (0x040000-0x0400FF, 256 bytes) ---
00040000                            ; Unique bank-front prelude. Starts with 0x00040002 and a repeated 0xFE73 motif before the
00040000                            ; later recurring header-like families begin.
00040000                            Bank040000_FrontHeaderLikeLeadIn_040000:
00040000                            	incbin "data/rom/bank_040000_07ffff.bin",$000000,$000100
00040100                            
00040100                            ; --- Candidate block A (0x040100-0x04025B, 348 bytes) ---
00040100                            ; Starts with the recurring FFFF 000A header-like prefix.
00040100                            Bank040000_FrontHeaderLikeDataBlockA_040100:
00040100                            	incbin "data/rom/bank_040000_07ffff.bin",$000100,$00015C
0004025C                            
0004025C                            ; --- Candidate block B (0x04025C-0x0403FF, 420 bytes) ---
0004025C                            ; Starts with the recurring FFFF 000E header-like prefix.
0004025C                            Bank040000_FrontHeaderLikeDataBlockB_04025C:
0004025C                            	incbin "data/rom/bank_040000_07ffff.bin",$00025C,$0001A4
00040400                            
00040400                            ; --- Candidate block C (0x040400-0x04053B, 316 bytes) ---
00040400                            ; Starts with a short 0000 0102 lead-in followed by the only current FFFF 001E variant.
00040400                            Bank040000_FrontHeaderLikeDataBlockC_040400:
00040400                            	incbin "data/rom/bank_040000_07ffff.bin",$000400,$00013C
0004053C                            
0004053C                            ; --- Candidate block D (0x04053C-0x0406C3, 392 bytes) ---
0004053C                            ; Starts with the same 0000 0102 lead-in shape seen at 0x040400, then transitions into a
0004053C                            ; second FFFF 000E-style block body.
0004053C                            Bank040000_FrontHeaderLikeDataBlockD_04053C:
0004053C                            	incbin "data/rom/bank_040000_07ffff.bin",$00053C,$000188
000406C4                            
000406C4                            ; --- Candidate block E (0x0406C4-0x0408D3, 528 bytes) ---
000406C4                            ; Returns to the recurring FFFF 000A header-like prefix.
000406C4                            Bank040000_FrontHeaderLikeDataBlockE_0406C4:
000406C4                            	incbin "data/rom/bank_040000_07ffff.bin",$0006C4,$000210
000408D4                            
000408D4                            ; --- Candidate block F (0x0408D4-0x0409F9, 294 bytes) ---
000408D4                            ; Final front-bank pocket before the explicit fill run. Also starts with FFFF 000A.
000408D4                            Bank040000_FrontHeaderLikeDataBlockF_0408D4:
000408D4                            	incbin "data/rom/bank_040000_07ffff.bin",$0008D4,$000126
000408D4                            	incbin "data/rom/bank_040000_07ffff.bin",$0008D4,$000126
000409FA                            
000409FA                            Bank040000_Fill_0409FA_040FFF:
000409FA                            	incbin "data/rom/bank_040000_07ffff.bin",$0009FA,$000606
00041000                            
00041000                            Bank040000_FlaggedRomReferenceTables_041000:
00041000                            	include "src/reference_gfx_bank/flagged_rom_reference_tables.asm"
00041000                            ; ROM range: 0x041000-0x041BFF
00041000                            ; Conservative front-of-bank split for a strongly regular 4-byte record island. The bytes fit
00041000                            ; a repeated [tag][24-bit ROM address] shape: the long local run at 0x041000-0x0418AB points
00041000                            ; into 0x041C00-0x07FF66, the following run at 0x0418AC-0x041B3F points into 0x0801CD-0x093FD0,
00041000                            ; then a short 16-entry tail table at 0x041B80-0x041BBF continues the same shape into
00041000                            ; 0x09414A-0x0961D7.
00041000                            ;
00041000                            ; Tag semantics remain only partly proven. Tag $01 is now strong enough to name as the planar-tile
00041000                            ; variant because every same-bank $01 target lands on one isolated 0x045842 tile block or one of the
00041000                            ; repeated 0x4C0-byte / 38-tile 4bpp graphics families split into the dedicated gfx tile modules.
00041000                            ; Tags $00 and $02 still remain structural until control flow or a loader proves what distinction they
00041000                            ; encode, and $FF stays an unused sentinel.
00041000                            
00041000                            Bank040000_LocalFlaggedRomReferenceTable_041000:
00041000 0000 0000                  	flagged_rom_ref FlaggedRomReferenceTag_02, Bank040000_LocalTableTargetedPayloadFront_041C00
00041004 0000 0000                  	flagged_rom_ref FlaggedRomReferenceTag_02, Bank040000_LocalTableTargetedPayloadRecord_041CCF
