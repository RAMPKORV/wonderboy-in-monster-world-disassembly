000A2400                            	include "src/z80_offset_bank/ff_five_byte_tuple_segment_c.asm"
000A2400                            ; ROM range: 0x0A2400-0x0A2585
000A2400                            ; This run continues the same FF-terminated five-byte tuple family. Every record ends at
000A2400                            ; a proven local $FF terminator, and every pre-terminator payload length remains a
000A2400                            ; multiple of 5 bytes, so the source exposes each stable record start directly in ROM
000A2400                            ; order while keeping the labels structural.
000A2400                            ;
000A2400                            ; The front half is no longer a thin wrapper around record-local incbins. The bytes now make
000A2400                            ; a few repeated subfamilies directly auditable in source: paired 0x60/0x68 variants around
000A2400                            ; tile pages 0x18/0x2E/0x37/0x49/0x4B, a compact 0x01-page cluster around 0xE0-0xFE, and a
000A2400                            ; late 0x60/0x61-page ladder that leads into the already split 0x0A2586 bridge records.
