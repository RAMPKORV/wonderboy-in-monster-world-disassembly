0009A348                            Bank080000_FFTerminatedCommandRecordWindowFront_09A348:
0009A348                            	include "src/z80_offset_bank/z80_command_records_front.asm"
0009A348                            ; ROM range: 0x09A348-0x09C007
0009A348                            ; FF-terminated command-record window split into ROM-order slices at every proven
0009A348                            ; local terminator. Labels stay structural until the tail-bank command decoder and
0009A348                            ; owning subsystem are identified from control flow.
0009A348                            
0009A348                            ; This tiny lead-in begins with one short tuple before the first true command records settle into
0009A348                            ; the same local-control and repeated byte-pair vocabulary that dominates the rest of the front window.
