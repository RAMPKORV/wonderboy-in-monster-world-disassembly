00020000                            ; ======================================================================
00020000                            ; src/text_bank.asm
00020000                            ; ROM range: 0x020000-0x03FFFF - dialogue, text, tables, and compressed tail data
00020000                            ; ======================================================================
00020000                            ; Bank-local ownership skeleton for the first fully banked mid-ROM region.
00020000                            ; This bank still needs deeper code/text/table recovery, but the upstream quiz slice at
00020000                            ; 0x021360-0x02171F, the adjacent name/text region at 0x021720-0x02245F, the first
00020000                            ; post-dictionary descriptor/index island at 0x022460-0x022DB7, a later sentinel-
00020000                            ; delimited word-record band at 0x023AB6-0x024537, and the next front continuation at
00020000                            ; 0x024538-0x02482B are now split into ROM-order modules. The bridge between those two
00020000                            ; larger structured islands is also partially split at the first local FF00 / FFFF
00020000                            ; sentinels, so the bank is no longer a single opaque slice.
00020000                            
00020000                            Bank020000_DialogueScriptContinuation_020000:
00020000                            	include "src/text_bank/dialogue_continuation.asm"
00020000                            ; ROM range: 0x020000-0x0201CF
00020000                            ; Dialogue/script text continuation from the core region. This region carries the tail
00020000                            ; of NPC dialogue strings that begin in core_005000_01ffff (the last bytes of the core
00020000                            ; binary end mid-word at 0x01FFFF and resume here at 0x020000). Each record is a
00020000                            ; null-terminated (0x00) chunk of dialogue bytes. Control codes: 0x05=end-of-string,
00020000                            ; 0x09=newline, 0x0B NN=speaker/format command, 0x0C NN=dictionary word lookup,
00020000                            ; 0x02=wrap, 0x03/0x04/0x06/0x07=undecoded controls, 0x0F NN=undecoded 2-byte op.
00020000                            ; The dictionary word table (168 words, indices 0x00-0xA7) is at 0x022026. Indices
00020000                            ; 0xA8-0xFF reference a second word table not yet located.
00020000                            
00020000                            Bank020000_DialogueScriptFrontContinuation_020000:
00020000 6E20 6109 6465 6570 200C+  	dc.b	"n a",$09,"deep ",$0C,$C5,".",$05
