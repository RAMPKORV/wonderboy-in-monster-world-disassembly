0009803B                            Bank080000_Z80ProgramMainBody_09803B:
0009803B                            
0009803B                            ; The first main-body helper resets the wide-record and slot tables, shifts one startup byte
0009803B                            ; out through 0x6000, emits three fixed setup bursts through 0x06F7/0x00E3/0x013E, and then
0009803B                            ; runs a three-step warmup loop that advances the inline sequence state via 0x0110/0x0155/
0009803B                            ; 0x019C before tail-jumping back into the countdown-driven tick below.
0009803B                            Bank080000_Z80ProgramInitializeSequencerState_09803B:
0009803B 2180 1BF9 36FF 2301 FF00+  	dc.b	$21,$80,$1B,$F9,$36,$FF,$23,$01,$FF,$00,$16,$00,$CF,$01,$80,$03
0009804B 15CF 2180 1C11 4000 0609+  	dc.b	$15,$CF,$21,$80,$1C,$11,$40,$00,$06,$09,$72,$19,$10,$FC,$1E,$20
0009805B 060A 7219 10FC 21D1 1E06+  	dc.b	$06,$0A,$72,$19,$10,$FC,$21,$D1,$1E,$06,$0A,$72,$19,$10,$FC,$3A
0009806B 0100 3200 602E 9006 08AF+  	dc.b	$01,$00,$32,$00,$60,$2E,$90,$06,$08,$AF,$CB,$25,$17,$32,$00,$60
0009807B 10F7 0E00 062B CDF7 060E+  	dc.b	$10,$F7,$0E,$00,$06,$2B,$CD,$F7,$06,$0E,$ED,$06,$26,$CD,$F7,$06
0009808B 3E2A 3223 1C4F 0627 CDF7+  	dc.b	$3E,$2A,$32,$23,$1C,$4F,$06,$27,$CD,$F7,$06,$21,$11,$7F,$36,$9F
0009809B 36BF 36DF 36FF CDE3 00CD+  	dc.b	$36,$BF,$36,$DF,$36,$FF,$CD,$E3,$00,$CD,$3E,$01,$3E,$01,$32,$2D
000980AB 1CAF 3200 1CAF 3206 1C3E+  	dc.b	$1C,$AF,$32,$00,$1C,$AF,$32,$06,$1C,$3E,$03,$32,$02,$1C,$CD,$10
000980BB 01CD 5501 CD9C 012A 161C+  	dc.b	$01,$CD,$55,$01,$CD,$9C,$01,$2A,$16,$1C,$26,$00,$ED,$5B,$14,$1C
000980CB 1922 161C 7C21 061C 8677+  	dc.b	$19,$22,$16,$1C,$7C,$21,$06,$1C,$86,$77,$CD,$0B,$07,$3A,$02,$1C
000980DB 3D20 D8CD 7F0B 18CD        	dc.b	$3D,$20,$D8,$CD,$7F,$0B,$18,$CD
000980E3                            
000980E3                            ; Emit one short startup burst, then three row-like writes with C = 1..3 through 0x06F7.
000980E3                            Bank080000_Z80ProgramEmitStartupBurst_0980E2:
