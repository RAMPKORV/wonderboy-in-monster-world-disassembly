0002482C                            ; ROM range: 0x02482C-0x03FFFF
0002482C                            ; Tail region of bank 020000.
0002482C                            ;
0002482C                            ; Structure:
0002482C                            ;   0x02482C  4-entry relative-offset table (10 bytes, terminated by 0xFF7B sentinel)
0002482C                            ;             Offsets are relative to the table base (0x02482C):
0002482C                            ;               0x0016 -> 0x024842  (sub-entry 0 within Block 1 RLE data)
0002482C                            ;               0x007A -> 0x0248A6  (sub-entry 1 within Block 1 RLE data)
0002482C                            ;               0x00EA -> 0x024916  (sub-entry 2 within Block 1 RLE data)
0002482C                            ;               0x015E -> 0x02498A  (sub-entry 3 within Block 1 RLE data)
0002482C                            ;               0xFF7B              (end-of-table sentinel)
0002482C                            ;   0x024836  RLE/compressed graphics data blocks, each terminated by 0xFF7B.
0002482C                            ;             Blocks 1-9 are confirmed by 0xFF7B terminators.
0002482C                            ;   0x035078  More compressed/data blocks. The next three are terminated by
0002482C                            ;             0xFF7A instead, and only the final 0x03C6E0-0x03FFFF tail still
0002482C                            ;             lacks a proven internal split.
0002482C                            ;
0002482C                            ; The 0x52, 0x4A, 0x5A byte values within block payloads are RLE opcodes;
0002482C                            ; 0xFF-heavy runs are fill patterns. This is consistent with Mega Drive
0002482C                            ; tile/sprite compressed graphics formats.
0002482C                            
0002482C                            ; --- Offset table (0x02482C-0x024835, 10 bytes) ---
0002482C                            ; 4 relative offsets into Block 1 payload + 0xFF7B end-of-table sentinel.
0002482C                            Bank020000_TailOffsetTable_02482C:
0002482C 0016 007A 00EA 015E FF7B   	dc.w	$0016,$007A,$00EA,$015E,$FF7B
00024836                            
00024836                            ; --- Block 1 (0x024836-0x025125, 2288 bytes) ---
00024836                            ; RLE-compressed graphics block. 12-byte header at 0x024836 followed by
00024836                            ; sub-entries at offsets 0x0016, 0x007A, 0x00EA, 0x015E from the offset table
00024836                            ; base (0x02482C). Block terminated by 0xFF7B at 0x025124.
00024836                            Bank020000_TailGfxBlock1_024836:
00024836                            	incbin "data/rom/bank_020000_03ffff.bin",$004836,$0008F0
00025126                            
