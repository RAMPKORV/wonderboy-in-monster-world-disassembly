0002123A 051D 0527 052F 0539 0000+  	dc.w	$051D,$0527,$052F,$0539,$0000,$0000,$0000,$0000
0002124A 0000 0000 0000 0000 0000+  	dc.w	$0000,$0000,$0000,$0000,$0000,$0000,$0000
