00021B80                            Bank020000_ShopInnOcarinaAndDictionaryText_021B80:
00021B80                            	include "src/text_bank/shop_inn_dictionary_text.asm"
00021B80                            ; ROM range: 0x021B80-0x02245F
00021B80                            ; Mixed text-bearing region with shop/inn prompts, Ocarina door guidance, and a null-
00021B80                            ; terminated dialogue dictionary. Control bytes are still only partly decoded, so keep
00021B80                            ; them byte-explicit while naming the proven higher-level text owners.
00021B80                            ; The equipment-shop offer at 0x021B80 is a template rather than an inline item list.
00021B80                            ; Tracing the init-region text builder at 0x001E6A shows that $0C enters an indirect stream
00021B80                            ; lookup rooted at 0x001CC10 entry 0 (= 0x0211CA): here $0C,$02 lands at 0x0211CC and
00021B80                            ; $0C,$03 lands at 0x0228EA. The parallel inn prompt's $0C,$05 lands at 0x022BD0.
00021B80                            ; Decimal price rendering itself is handled by the nearby formatter at 0x001F46.
00021B80                            
00021B80                            Bank020000_EquipmentShopOfferText_021B80:
00021B80 596F 7520 6861 7665 2061+  	dc.b	"You have a",$09,"discriminating eye.",$09,$05,$09,"That's",$09
00021BA8 0C02 2E09 0549 7420 636F+  	dc.b	$0C,$02,".",$09,$05,"It costs",$0C,$03
00021BB7 2E05 0957 6F75 6C64 2079+  	dc.b	".",$05,$09,"Would you like to",$09,"purchase it?",$0C,$00
