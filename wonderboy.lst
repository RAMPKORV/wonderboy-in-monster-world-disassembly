00098030                            
00098030                            Bank080000_Z80ProgramJumpStub_098030:
00098030 E32B E3C3 8C0F FFFF        	dc.b	$E3,$2B,$E3,$C3,$8C,$0F,$FF,$FF
00098038                            
00098038                            Bank080000_Z80ProgramRetiStub_098038:
00098038 00ED 4D                    	dc.b	$00,$ED,$4D
