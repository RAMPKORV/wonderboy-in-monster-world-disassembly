00040000                            	include "src/bank040000.asm"
00040000                            ; ROM range: 0x040000-0x07FFFF
00040000                            ; Late-ROM bank split into bank-local slices. The first confirmed structure here was a
00040000                            ; long 0xFF fill run at 0x0409FA-0x040FFF; the next proven cluster at 0x041000-0x041BFF is
00040000                            ; now explicit as a flagged ROM-reference table island with two smaller 0xFF fill gaps, and
00040000                            ; the first four chunks of its local-target payload family are split further at
00040000                            ; 0x041C00-0x07FF66, leaving only a tiny trailing bank remainder.
00040000                            
00040000                            Bank040000_FrontHeaderLikeData_040000:
00040000                            	include "src/bank040000_front_blocks.asm"
00040000                            ; ROM range: 0x040000-0x0409F9
00040000                            ; Front data island before the explicit 0x0409FA-0x040FFF fill run.
00040000                            ;
00040000                            ; This span is still opaque at the subsystem level, but it no longer needs to stay as one
00040000                            ; monolithic incbin. Several recurring header-like starts are now explicit in ROM order:
00040000                            ;   0x040100  starts with FFFF 000A
00040000                            ;   0x04025C  starts with FFFF 000E
00040000                            ;   0x040400  starts with 0000 0102 ... FFFF 001E
00040000                            ;   0x04053C  starts with 0000 0102 ... FFFF 000E
00040000                            ;   0x0406C4  starts with FFFF 000A
00040000                            ;   0x0408D4  starts with FFFF 000A
00040000                            ; Those signatures recur within the same front slice and mark cleaner boundaries than one
00040000                            ; bank-front blob, even though the loader and exact format are still unresolved.
00040000                            
00040000                            ; --- Front lead-in (0x040000-0x0400FF, 256 bytes) ---
00040000                            ; Unique bank-front prelude. Starts with 0x00040002 and a repeated 0xFE73 motif before the
00040000                            ; later recurring header-like families begin.
00040000                            Bank040000_FrontHeaderLikeLeadIn_040000:
00040000                            	incbin "data/rom/bank_040000_07ffff.bin",$000000,$000100
00040100                            
00040100                            ; --- Candidate block A (0x040100-0x04025B, 348 bytes) ---
00040100                            ; Starts with the recurring FFFF 000A header-like prefix.
00040100                            Bank040000_FrontHeaderLikeDataBlockA_040100:
00040100                            	incbin "data/rom/bank_040000_07ffff.bin",$000100,$00015C
0004025C                            
0004025C                            ; --- Candidate block B (0x04025C-0x0403FF, 420 bytes) ---
0004025C                            ; Starts with the recurring FFFF 000E header-like prefix.
0004025C                            Bank040000_FrontHeaderLikeDataBlockB_04025C:
0004025C                            	incbin "data/rom/bank_040000_07ffff.bin",$00025C,$0001A4
00040400                            
00040400                            ; --- Candidate block C (0x040400-0x04053B, 316 bytes) ---
00040400                            ; Starts with a short 0000 0102 lead-in followed by the only current FFFF 001E variant.
00040400                            Bank040000_FrontHeaderLikeDataBlockC_040400:
00040400                            	incbin "data/rom/bank_040000_07ffff.bin",$000400,$00013C
0004053C                            
0004053C                            ; --- Candidate block D (0x04053C-0x0406C3, 392 bytes) ---
0004053C                            ; Starts with the same 0000 0102 lead-in shape seen at 0x040400, then transitions into a
0004053C                            ; second FFFF 000E-style block body.
0004053C                            Bank040000_FrontHeaderLikeDataBlockD_04053C:
0004053C                            	incbin "data/rom/bank_040000_07ffff.bin",$00053C,$000188
000406C4                            
000406C4                            ; --- Candidate block E (0x0406C4-0x0408D3, 528 bytes) ---
000406C4                            ; Returns to the recurring FFFF 000A header-like prefix.
000406C4                            Bank040000_FrontHeaderLikeDataBlockE_0406C4:
000406C4                            	incbin "data/rom/bank_040000_07ffff.bin",$0006C4,$000210
000408D4                            
000408D4                            ; --- Candidate block F (0x0408D4-0x0409F9, 294 bytes) ---
000408D4                            ; Final front-bank pocket before the explicit fill run. Also starts with FFFF 000A.
000408D4                            Bank040000_FrontHeaderLikeDataBlockF_0408D4:
000408D4                            	incbin "data/rom/bank_040000_07ffff.bin",$0008D4,$000126
000408D4                            	incbin "data/rom/bank_040000_07ffff.bin",$0008D4,$000126
000409FA                            
000409FA                            Bank040000_Fill_0409FA_040FFF:
000409FA                            	incbin "data/rom/bank_040000_07ffff.bin",$0009FA,$000606
00041000                            
00041000                            Bank040000_FlaggedRomReferenceTables_041000:
00041000                            	include "src/bank040000_tables.asm"
00041000                            ; ROM range: 0x041000-0x041BFF
00041000                            ; Conservative front-of-bank split for a strongly regular 4-byte record island. The bytes fit
00041000                            ; a repeated [tag][24-bit ROM address] shape: the long local run at 0x041000-0x0418AB points
00041000                            ; into 0x041C00-0x07FF66, the following run at 0x0418AC-0x041B3F points into 0x0801CD-0x093FD0,
00041000                            ; then a short 16-entry tail table at 0x041B80-0x041BBF continues the same shape into
00041000                            ; 0x09414A-0x0961D7. Keep the labels structural until the consumer and the meaning of the top
00041000                            ; tag byte are proven from control flow.
00041000                            
