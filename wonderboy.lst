00022460                            Bank020000_StructuredDescriptorAndIndexData_022460:
00022460                            	include "src/text_bank/descriptor_and_index_data.asm"
00022460                            ; ROM range: 0x022460-0x022DB7
00022460                            ; The first post-dictionary bank020000 island is structurally dense rather than plain text.
00022460                            ; The front 0x60 bytes are six 0x10-byte same-bank reference descriptors, followed by a
00022460                            ; monotone offset table whose values fit a payload base at 0x0225D8. That payload is no
00022460                            ; longer one coarse blob either: after an 0x8A-byte lead-in, the same offset table fans out
00022460                            ; into mostly 6-byte short records with a smaller set of 8-byte variants before the later
00022460                            ; 0x02292C-0x022AEB repeated 0x10-byte descriptor band and a trailing variable-length word
00022460                            ; region at 0x022AEC-0x022DB7 whose front records are mostly delimited by $FFFF, followed by
00022460                            ; a short repeated $0BFF word band and then several smaller $FF00-terminated compact word
00022460                            ; records. The consuming driver is still open, so keep the labels structural.
00022460                            
