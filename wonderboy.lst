000211CA                            Bank020000_BankRelativeTextIndexData_0211CA:
000211CA                            	include "src/text_bank/text_pointer_tables.asm"
000211CA                            ; ROM range: 0x0211CA-0x02135F
000211CA                            ; This front-of-bank island is structured index data rather than more opaque prose. Four
000211CA                            ; absolute longwords point at bank-local table families, followed by two bank-relative
000211CA                            ; offset tables that target earlier text-bearing records in the same bank.
000211CA                            ; The init-region text builder at 0x001ED0 also reuses entry 0 here as a word-offset root for
000211CA                            ; control-family $0C expansion: for example, the shop offer's $0C,$03 resolves through this
000211CA                            ; base to 0x0228EA, and the inn prompt's $0C,$05 resolves to 0x022BD0.
000211CA                            
000211CA                            Bank020000_LocalTextTablePointerList_0211CA:
000211CA 0000 0000                  	dc.l	Bank020000_BankRelativeTextOffsetTableA_0211DA
000211CE 0000 0000                  	dc.l	Bank020000_InventoryNameOffsetTable_021720
000211D2 0000 0000                  	dc.l	Bank020000_WorldKeywordOffsetTable_021A06
000211D6 0000 0000                  	dc.l	Bank020000_OcarinaMelodyUnknownData_021FCA
000211DA                            
000211DA                            ; 52 live bank-relative offsets followed by 11 zero sentinels. Every nonzero word points
000211DA                            ; back into 0x0201D0-0x020539, so keep the table structural until its consumer is proven.
