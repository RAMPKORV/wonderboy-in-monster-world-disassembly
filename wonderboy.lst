00099A85                            Bank080000_Z80CommandFront_099A85:
00099A85                            	include "src/z80_offset_bank/z80_command_setup.asm"
00099A85                            ; ROM range: 0x099A85-0x09A347
00099A85                            ; Front command-owner slice inside the 0x098000-0x09F776 non-fill island.
00099A85                            ;
00099A85                            ; Keep this separate from the Z80-program front, pre-descriptor records, and later FF-terminated
00099A85                            ; command windows so the mid-bank island reads in subsystem-sized steps instead of one oversized
00099A85                            ; catch-all file. The bytes here now justify four structural owners in ROM order: a zero-fill
00099A85                            ; gap at 0x099A85-0x099AFF, a 25-word command lead-in at 0x099B00, a mostly same-window
00099A85                            ; offset table at 0x099B32, and a source-visible 0x099BB0-0x09A347 table-targeted command front
00099A85                            ; whose longer targets are already split at proven local FF, FD, and FE boundaries.
00099A85                            
00099A85                            Bank080000_ZeroFill_099A85:
00099A85 0000 0000 0000 0000 0000+  	dc.b	$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00
00099A95 0000 0000 0000 0000 0000+  	dc.b	$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00
00099AA5 0000 0000 0000 0000 0000+  	dc.b	$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00
