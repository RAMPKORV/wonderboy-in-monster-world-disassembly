00080000                            ; ======================================================================
00080000                            ; src/z80_offset_bank.asm
00080000                            ; ROM range: 0x080000-0x0BFFFF - tail-bank payloads, Z80 resources, and offset-tree data
00080000                            ; ======================================================================
00080000                            ; Tail-bank owner split around the largest confirmed 0xFF fill runs. The front non-fill
00080000                            ; slice is no longer one opaque bank chunk either: the cross-bank flagged ROM-reference
00080000                            ; tables at 0x0418AC-0x041BBF now prove 178 stable target starts inside 0x0801CD-0x0961D7,
00080000                            ; so that pre-fill payload is split into two ROM-order include modules with the untargeted
00080000                            ; gaps left explicit in this file.
00080000                            
00080000                            Bank080000:
00080000                            	incbin "data/rom/bank_080000_0bffff.bin",$000000,$0001CD
000801CD                            
000801CD                            Bank080000_CrossBankTableTargetedPayloadFront_0801CD:
000801CD                            	include "src/z80_offset_bank/cross_bank_records_front.asm"
000801CD                            ; ROM range: 0x0801CD-0x093FD0
000801CD                            ; The cross-bank flagged ROM-reference tables at 0x0418AC-0x041BBF point monotonically
000801CD                            ; into this bank080000 payload span. That evidence now exposes 162 stable record starts in
000801CD                            ; ROM order, so this previously opaque front slice is no longer one monolithic incbin.
000801CD                            
000801CD                            Bank080000_CrossBankTableTargetedRecord_0801CD:
000801CD                            	incbin "data/rom/bank_080000_0bffff.bin",$0001CD,$000234
