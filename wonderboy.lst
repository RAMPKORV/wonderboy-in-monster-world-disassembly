00005000                            	include "src/core.asm"
00005000                            ; ROM range: 0x005000-0x01FFFF
00005000                            ; Early engine/core body kept mostly opaque until routine boundaries are mapped.
00005000                            ; The front of this file continues the task/input helper chain that begins at `0x004FEE`
00005000                            ; in `src/vblank.asm`. The `0x005016-0x00505C` helpers currently look like a compact
00005000                            ; input-sequence stream built from (duration,value) byte pairs in `0xFF1400`, reusing
00005000                            ; the selected-input mirror at `0x8A7A-0x8A7D` as playback state. The bootstrap
00005000                            ; display-setup stub at `0x005170-0x0051C5` and the controller-read helpers at
00005000                            ; `0x0051C6-0x005260` are now source-authored in ROM order; the broader engine body
00005000                            ; still stays opaque after that point.
