000A10AB                            Bank080000_FFTerminatedFiveByteTupleFamily_0A10AB:
000A10AB                            	include "src/z80_offset_bank/ff_terminated_five_byte_tuples.asm"
000A10AB                            ; ROM range: 0x0A10AB-0x0A34FF
000A10AB                            ; FF-terminated five-byte tuple family inside the second non-fill tail-bank island.
000A10AB                            ;
000A10AB                            ; The middle tail-bank lead-in is no longer one monolithic blob. Most of this span breaks into
000A10AB                            ; FF-terminated records whose pre-terminator payload length is a multiple of 5 bytes. The few
000A10AB                            ; bridge pockets that do not fit that cadence are now explicit as short FF-terminated mixed
000A10AB                            ; records, and several former anomaly pockets also stand explicitly as isolated FF-terminated
000A10AB                            ; records whose tuples merely embed $FF in data fields. Keep the labels structural until the
000A10AB                            ; loader proves whether these tuples are layout, object, script, or another resource family.
000A10AB                            
000A10AB                            Bank080000_FFTerminatedFiveByteTupleRecord_0A10AB:
000A10AB 0B60 0CF8 F8               	dc.b	$0B,$60,$0C,$F8,$F8
