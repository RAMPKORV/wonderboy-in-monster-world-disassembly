000A0000                            Bank080000_OffsetTreePayload_0A0000_0A4C76:
000A0000                            	include "src/z80_offset_bank/offset_tree_data.asm"
000A0000                            ; ROM range: 0x0A0000-0x0A4C76
000A0000                            ; Conservative split of the second non-fill tail-bank island. The front 0x07C6 bytes are
000A0000                            ; dominated by big-endian words that mostly point back into this same 0x0A0000-0x0A4C76
000A0000                            ; region, forming a nested offset-table tree rather than plain opaque blob data. The
000A0000                            ; downstream payload bytes are still structurally dense and unresolved. The first proven
000A0000                            ; regular band now extends through 0x0A0B25 as a continued 0x18-byte four-tuple family.
000A0000                            ; The following lead-in is no longer one opaque mixed patch either: its front 0x153 bytes
000A0000                            ; now resolve into 26 short FF-terminated structural records before a final 10-byte tail,
000A0000                            ; then several narrower FF-terminated 6-byte record bands stand apart from the surrounding
000A0000                            ; patch-like payload, and the next large span at 0x0A10AB-0x0A34FF further decomposes into
000A0000                            ; long FF-terminated 5-byte-tuple runs separated by short anomaly gaps. Keep the remaining
000A0000                            ; ownership structural until the consuming loader/decoder is identified.
000A0000                            
