000A0000                            Bank080000_MidData_0A0000_0A4C76:
000A0000                            	include "src/bank080000_a0000.asm"
000A0000                            ; ROM range: 0x0A0000-0x0A4C76
000A0000                            ; Conservative split of the second non-fill tail-bank island. The front 0x07C6 bytes are
000A0000                            ; dominated by big-endian words that mostly point back into this same 0x0A0000-0x0A4C76
000A0000                            ; region, forming a nested offset-table tree rather than plain opaque blob data. The
000A0000                            ; downstream payload bytes are still structurally dense and unresolved. The first proven
000A0000                            ; regular band now extends through 0x0A0B25 as a continued 0x18-byte four-tuple family.
000A0000                            ; The following lead-in is still mixed overall, but several narrower FF-terminated 6-byte
000A0000                            ; record bands now stand apart from the surrounding patch-like payload, and the next large
000A0000                            ; span at 0x0A10AB-0x0A34FF now further decomposes into long FF-terminated 5-byte-tuple
000A0000                            ; runs separated by short anomaly gaps. Keep the remaining ownership structural until the
000A0000                            ; consuming loader/decoder is identified.
000A0000                            
