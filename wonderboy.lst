00098000                            Bank080000_MidData_098000_09F776:
00098000                            	include "src/bank080000_mid.asm"
00098000                            ; ROM range: 0x098000-0x09F776
00098000                            ; Conservative split of the first non-fill tail-bank island. The front 0x098000-0x0991FF
00098000                            ; span still begins with a strongly Z80/opcode-dense code body rather than plain 68k or
00098000                            ; obvious asset data, but it no longer stays monolithic: the final 0x185 bytes are now
00098000                            ; explicit as two odd-aligned little-endian word lookup tables and one trailing zero byte.
00098000                            ; The next 0x099200-0x09991F span is also split separately because it is structurally cleaner:
00098000                            ; monotone byte bands, a fixed 19-byte record family, smaller mixed/control tails, and a short
00098000                            ; local-offset/word trailer leading into the already split descriptor-header region plus the
00098000                            ; adjacent fixed-record layout band. The larger command region still keeps its front lead-in
00098000                            ; and bank-local offset table explicit before the denser command records, and the formerly
00098000                            ; monolithic trailing command body at 0x09A348-0x09F776 remains divided into three ROM-order
00098000                            ; source windows, each further split at every proven local 0xFF terminator so the
00098000                            ; command-record cadence is explicit even before the subsystem owner is clearer.
00098000                            
00098000                            	include "src/bank080000_mid_z80.asm"
00098000                            ; ROM range: 0x098000-0x0991FF
00098000                            ; Front slice inside the 0x098000-0x09F776 non-fill tail-bank island.
00098000                            ;
00098000                            ; The front 0x107B bytes remain a strongly opcode-dense Z80-like code body, but the
00098000                            ; tail is no longer left inside the same monolithic incbin. The final 0x185 bytes tighten
00098000                            ; into two odd-aligned little-endian word lookup tables followed by one trailing zero byte.
00098000                            ;
00098000                            ; The first table at 0x09907B-0x09913C rises from 0x028E to 0x051C across 97 entries,
00098000                            ; while the second at 0x09913D-0x0991FE falls from 0x0349 to 0x01A4 across another 97
00098000                            ; entries. Keep the names structural until the Z80-side consumer is proven.
00098000                            
00098000                            Bank080000_Z80LikeCodeBlock_098000:
00098000                            Bank080000_Z80LikeCodeBody_098000:
00098000                            	incbin "data/rom/bank_080000_0bffff.bin",$018000,$00107B
